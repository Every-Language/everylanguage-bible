{
  "expo": {
    "name": "el-bible",
    "slug": "el-bible",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.everylanguage.elbible",
      "infoPlist": {
        "UIBackgroundModes": [
          "background-fetch",
          "background-processing",
          "audio"
        ],
        "NSMicrophoneUsageDescription": "This app needs access to microphone for audio playback controls.",
        "AVAudioSession": {
          "Category": "playback",
          "Mode": "default",
          "Options": [
            "allowBluetooth",
            "allowBluetoothA2DP",
            "allowAirPlay",
            "defaultToSpeaker"
          ]
        }
      }
    },
    "android": {
      "package": "com.everylanguage.elbible",
      "permissions": [
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET"
      ],
      "foregroundServiceType": ["mediaPlayback"],
      "allowBackup": true
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      "expo-notifications",
      "expo-audio",
      "expo-sqlite",
      "expo-background-fetch",
      "expo-task-manager"
    ],
    "scheme": "el-bible",
    "newArchEnabled": true,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8d2fb795-58b5-4eda-98b7-2cf9c20cf82c"
      }
    },
    "owner": "every-language"
  }
}
